{
  "env": {
    "browser": true,
    "es2021": true,
    "jquery": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": 2021,
    "sourceType": "module"
  },
  "globals": {
    "globalThis": true,
    "geweb_aisearch": true,
    "GewebAISearchSourceMethods": true,
    "GewebAisearchMarkdown": true
  },
  "rules": {
    "no-undef": "error",
    "no-unused-vars": "error",
    "no-console": "warn",
    "eqeqeq": "error",
    "curly": "error",
    "brace-style": "error",
    "no-var": "error",
    "prefer-const": "error",
    "no-implicit-globals": "error",
    "semi": "error",
    "prefer-arrow-callback": "warn",
    "no-empty": "warn",
    "no-fallthrough": "error"
  }
}
